      "Bash(/Users/steve/.local/bin/tmux-claude-status complete \"Tmux Configuration Complete\")",
      "Bash(tmux show-options:*)",
      "Bash(tmux show-hooks:*)",
      "Bash(tmux set-window-option:*)",
      "Bash(grep:*)",
      "Bash(tmux rename-window:*)",
      "Bash(tmux list-sessions:*)",
      "Bash(tmux rename-session:*)",
      "Bash(tmux bind:*)",
      "Bash(networksetup:*)",
      "Bash(mkdir:*)",
      "Bash(echo:*)",
      "Bash(tmux attach:*)",
      "Bash(tmux set-environment:*)",
      "Bash(tmux show-environment:*)",
      "Bash(tmux new-session:*)",
      "Bash(tmux set-option:*)",
      "Bash(gh repo view:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(rm:*)",
      "Bash(git clone:*)",
      "Bash(git checkout:*)",
      "Bash(stow:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(gh repo edit:*)",
      "Bash(rm:*)",
      "Bash(git rm:*)",
      "Bash(git log:*)",
      "Bash(git filter-branch:*)",
      "Bash(FILTER_BRANCH_SQUELCH_WARNING=1 git filter-branch --force --index-filter 'git rm --cached --ignore-unmatch .viminfo' --prune-empty --tag-name-filter cat -- --all)",
      "Bash(osascript:*)",
      "Bash(printf \"\\a\")",
      "Bash(tmux display:*)",
      "Bash(git gc:*)",
      "Bash(tmux set-hook:*)",
      "Bash(FILTER_BRANCH_SQUELCH_WARNING=1 git filter-branch --force --index-filter 'git rm --cached --ignore-unmatch .viminfo dotfiles/.viminfo vim/.viminfo' --prune-empty --tag-name-filter cat -- --all)",
      "Bash(git branch:*)",
      "Bash(sudo pmset:*)",
      "Bash(pmset:*)",
      "WebSearch"
    ],
    "deny": []
