#!/bin/bash
# Ghostty entry point: deterministic session naming for reliable restoration.
# First window gets "main"; subsequent windows get "main-N".
tmux="${TMUX_BIN:-tmux}"

# Clean up stale main-N sessions (unattached, inactive >24h)
now=$(date +%s)
"$tmux" list-sessions -F '#{session_name} #{session_attached} #{session_activity}' 2>/dev/null \
  | while read -r name attached activity; do
      if [[ "$name" =~ ^main-[0-9]+$ ]] && [ "$attached" = "0" ]; then
        age=$(( now - activity ))
        if [ "$age" -gt 86400 ]; then
          "$tmux" kill-session -t "$name"
        fi
      fi
    done

# Create main if it doesn't exist
if ! "$tmux" has-session -t main 2>/dev/null; then
  exec "$tmux" new-session -s main
fi

# Attach to main if no client is using it
if [ "$("$tmux" display -t main -p '#{session_attached}')" = "0" ]; then
  exec "$tmux" attach-session -t main
fi

# Find lowest-numbered unattached main-N session
unattached=$("$tmux" list-sessions -F '#{session_name} #{session_attached}' \
  | awk '$1 ~ /^main-[0-9]+$/ && $2 == "0" { print $1 }' \
  | sort -t- -k2 -n \
  | head -1)

if [ -n "$unattached" ]; then
  exec "$tmux" attach-session -t "$unattached"
fi

# Create next main-N
existing=$("$tmux" list-sessions -F '#{session_name}' \
  | sed -n 's/^main-\([0-9]*\)$/\1/p' \
  | sort -n \
  | tail -1)
next=$(( ${existing:-0} + 1 ))
exec "$tmux" new-session -s "main-$next"
