#!/usr/bin/env bash
set -euo pipefail

AEROSPACE_BIN="${AEROSPACE_BIN:-aerospace}"
GHOSTTY_APP_ID="com.mitchellh.ghostty"
TERMINAL_WORKSPACE='~'

ghostty_count() {
  "$AEROSPACE_BIN" list-windows --monitor all --app-bundle-id "$GHOSTTY_APP_ID" --count 2>/dev/null || echo 0
}

focused_workspace() {
  "$AEROSPACE_BIN" list-workspaces --focused 2>/dev/null | head -n1
}

terminal_monitor_id() {
  local monitors_json terminal_id
  monitors_json="$("$AEROSPACE_BIN" list-monitors --json 2>/dev/null)"

  terminal_id="$(printf '%s' "$monitors_json" | jq -r '
    if length == 2 then
      (map(select(."monitor-is-main" == false))[0]."monitor-id" // empty)
    else
      empty
    end
  ')"

  if [[ -z "${terminal_id:-}" ]]; then
    terminal_id="$(printf '%s' "$monitors_json" | jq -r '
      (map(select(."monitor-is-main" == true))[0]."monitor-id")
      // .[0]."monitor-id"
      // empty
    ')"
  fi

  printf '%s\n' "$terminal_id"
}

ghostty_window_line() {
  "$AEROSPACE_BIN" list-windows --monitor all --app-bundle-id "$GHOSTTY_APP_ID" \
    --format '%{window-id}|%{monitor-id}|%{workspace}' 2>/dev/null | sort -t'|' -k1,1nr | head -n1
}

route_first_window() {
  local count line window_id monitor_id workspace target_monitor_id
  count="$(ghostty_count)"
  [[ "$count" -eq 1 ]] || exit 0

  line="$(ghostty_window_line)"
  [[ -n "$line" ]] || exit 0

  IFS='|' read -r window_id monitor_id workspace <<<"$line"
  target_monitor_id="$(terminal_monitor_id)"
  [[ -n "$target_monitor_id" ]] || exit 0

  if [[ "$monitor_id" != "$target_monitor_id" ]]; then
    "$AEROSPACE_BIN" move-node-to-monitor --window-id "$window_id" "$target_monitor_id" >/dev/null 2>&1 || true
  fi

  if [[ "$workspace" != "$TERMINAL_WORKSPACE" ]]; then
    "$AEROSPACE_BIN" move-node-to-workspace --window-id "$window_id" --focus-follows-window "$TERMINAL_WORKSPACE" >/dev/null 2>&1 || true
  else
    "$AEROSPACE_BIN" workspace "$TERMINAL_WORKSPACE" >/dev/null 2>&1 || true
  fi
}

open_first_window() {
  osascript \
    -e 'tell application "Ghostty" to activate' \
    -e 'tell application "Ghostty" to new window' \
    >/dev/null
}

wait_for_window() {
  local attempt
  for attempt in $(seq 1 30); do
    if [[ "$(ghostty_count)" -gt 0 ]]; then
      return 0
    fi
    sleep 0.1
  done
  return 1
}

toggle_workspace() {
  local current_workspace
  current_workspace="$(focused_workspace)"

  if [[ "$current_workspace" == "$TERMINAL_WORKSPACE" ]]; then
    "$AEROSPACE_BIN" workspace-back-and-forth >/dev/null 2>&1 || true
    exit 0
  fi

  if [[ "$(ghostty_count)" -eq 0 ]]; then
    open_first_window
    wait_for_window || exit 1
    route_first_window
  fi

  "$AEROSPACE_BIN" workspace "$TERMINAL_WORKSPACE" >/dev/null 2>&1 || true
}

case "${1:-toggle}" in
  toggle)
    toggle_workspace
    ;;
  route-first-window)
    route_first_window
    ;;
  *)
    echo "usage: $(basename "$0") [toggle|route-first-window]" >&2
    exit 1
    ;;
esac
