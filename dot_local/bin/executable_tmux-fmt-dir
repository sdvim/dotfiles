#!/bin/bash
dir="$1"

alias_dir() {
  local path="$1" base="$2" alias="$3"
  if [[ "$path" == */"$base"/* || "$path" == */"$base" ]]; then
    echo "$alias"; return 0
  elif [[ "$path" == */"$base"-* ]]; then
    local suffix="${path#*/"$base"-}"
    suffix="${suffix%%/*}"
    echo "$alias-$suffix"; return 0
  fi
  return 1
}

alias_dir "$dir" "nix-config" "nix" && exit
alias_dir "$dir" "courtyard-frontend" "cyfe" && exit

case "$dir" in
  "$HOME") echo "~" ;;
  *)              basename "$dir" ;;
esac
