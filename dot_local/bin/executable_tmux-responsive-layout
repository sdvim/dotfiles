#!/usr/bin/env bash
# Automatically break panes into windows when terminal is narrow,
# and rejoin them when it grows back. Triggered by client-resized hook.
#
# Usage:
#   tmux-responsive-layout          # auto (uses client width + hysteresis)
#   tmux-responsive-layout break    # force break regardless of width
#   tmux-responsive-layout join     # force join regardless of width

set -euo pipefail

BREAK_THRESHOLD=100
JOIN_THRESHOLD=130

MODE="${1:-auto}"

if [ "$MODE" = "auto" ]; then
  WIDTH=$(tmux display -p '#{client_width}')
  STATE=$(tmux show -qvs @responsive_state 2>/dev/null || true)

  if [ "$WIDTH" -lt "$BREAK_THRESHOLD" ] && [ "$STATE" != "broken" ]; then
    MODE="break"
  elif [ "$WIDTH" -ge "$JOIN_THRESHOLD" ] && [ "$STATE" = "broken" ]; then
    MODE="join"
  else
    exit 0
  fi
fi

if [ "$MODE" = "break" ]; then
  # For each window with more than one pane, break extras into their own windows
  while IFS=' ' read -r win panes; do
    [ -z "$win" ] && continue
    [ "$panes" -le 1 ] && continue

    # Skip zoomed windows
    zoomed=$(tmux display -t "$win" -p '#{window_zoomed_flag}' 2>/dev/null || echo "0")
    [ "$zoomed" = "1" ] && continue

    # Break all panes except the first (active pane stays)
    pane_ids=$(tmux list-panes -t "$win" -F '#{pane_id}' | tail -n +2)
    for pane in $pane_ids; do
      new_win=$(tmux break-pane -d -s "$pane" -P -F '#{window_id}' 2>/dev/null) || continue
      tmux set-option -w -t "$new_win" @responsive_group "$win" 2>/dev/null || true
    done
  done < <(tmux list-windows -F '#{window_id} #{window_panes}')

  tmux set -s @responsive_state broken

elif [ "$MODE" = "join" ]; then
  # Find all windows tagged with @responsive_group and rejoin them
  for win in $(tmux list-windows -F '#{window_id}'); do
    group=$(tmux show -wqv -t "$win" @responsive_group 2>/dev/null) || true
    [ -z "$group" ] && continue

    # Check target window still exists
    if tmux display -t "$group" -p '#{window_id}' >/dev/null 2>&1; then
      pane=$(tmux list-panes -t "$win" -F '#{pane_id}' | head -1)
      tmux join-pane -d -s "$pane" -t "$group" 2>/dev/null || true
    fi

    # Clear the tag (window may have been consumed by join-pane)
    tmux set-option -wu -t "$win" @responsive_group 2>/dev/null || true
  done

  tmux set -s @responsive_state normal
fi
